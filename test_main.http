@baseUrl = http://127.0.0.1:8000
# Debug API endpoints for the FastAPI application
# This file (test_main.http) was AI generated!

### 1) List all items (should be empty at first)
GET {{baseUrl}}/items
Accept: application/json

### 2) Create item 1
POST {{baseUrl}}/items
Content-Type: application/json

{
  "name": "Example Item",
  "description": "Item #1"
}

### 3) Create item 2
POST {{baseUrl}}/items
Content-Type: application/json

{
  "name": "Example Item 2",
  "description": "Item #2"
}

### 4) List all items (should show 2)
GET {{baseUrl}}/items
Accept: application/json

### 5) Get item by ID (existing)
GET {{baseUrl}}/items/1
Accept: application/json

### 6) Update item by ID
PUT {{baseUrl}}/items/1
Content-Type: application/json

{
  "name": "Example Item - Updated",
  "description": "Item #1 - Updated"
}

### 7) Delete item by ID
DELETE {{baseUrl}}/items/2
Accept: application/json

### 8) Get non-existent item (should be 404)
GET {{baseUrl}}/items/999
Accept: application/json
